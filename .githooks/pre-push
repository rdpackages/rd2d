#!/bin/sh

set -eu

if [ "${RD2D_SKIP_PRE_PUSH:-}" = "1" ]; then
  echo "Skipping rd2d pre-push checks because RD2D_SKIP_PRE_PUSH=1."
  exit 0
fi

if [ "${OS:-}" = "Windows_NT" ]; then
  unset LC_ALL
  unset LC_CTYPE
fi

RSCRIPT_BIN="${RSCRIPT:-Rscript}"
if ! command -v "$RSCRIPT_BIN" >/dev/null 2>&1; then
  if [ -x "/c/Program Files/R/R-4.6.0/bin/Rscript.exe" ]; then
    RSCRIPT_BIN="/c/Program Files/R/R-4.6.0/bin/Rscript.exe"
  else
    echo "Rscript was not found. Set RSCRIPT=/path/to/Rscript or install R on PATH." >&2
    exit 1
  fi
fi

"$RSCRIPT_BIN" scripts/check-local.R --pre-push
